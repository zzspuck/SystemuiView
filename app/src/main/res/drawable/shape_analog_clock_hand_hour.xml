        android:width="@dimen/dp50"
        android:height="@dimen/dp250"
        android:bottom="@dimen/dp230"
        android:gravity="bottom">
        <shape android:shape="rectangle">

            <solid android:color="@color/bg_analog_clock_hand_hour" />

            <corners android:radius="@dimen/dp60" />

            <padding
